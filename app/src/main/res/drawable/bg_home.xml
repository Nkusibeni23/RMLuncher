<?xml version="1.0" encoding="utf-8"?>
<!-- Branded RMSoft home wallpaper: soft green glow at the top on a light canvas. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <color android:color="@color/rm_canvas" />
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="560dp"
                android:centerX="0.5"
                android:centerY="0.02"
                android:startColor="#663FD07F"
                android:endColor="#00F4F7F5" />
        </shape>
    </item>
</layer-list>
