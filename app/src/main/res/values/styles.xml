<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Settings.SectionLabel" parent="">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">22dp</item>
        <item name="android:layout_marginBottom">8dp</item>
        <item name="android:layout_marginStart">4dp</item>
        <item name="android:textColor">@color/rmsoft_accent</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <style name="Settings.Card" parent="">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">vertical</item>
        <item name="android:background">@drawable/bg_settings_card</item>
        <item name="android:padding">18dp</item>
    </style>

    <style name="Settings.RowLabel" parent="">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">10dp</item>
        <item name="android:textColor">@color/rmsoft_text_secondary</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="Settings.InfoLabel" parent="">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/rmsoft_text_tertiary</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="Settings.InfoValue" parent="">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">2dp</item>
        <item name="android:textColor">@color/rmsoft_text_primary</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="Settings.InfoDivider" parent="">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">0.5dp</item>
        <item name="android:layout_marginTop">14dp</item>
        <item name="android:layout_marginBottom">14dp</item>
        <item name="android:background">@color/rmsoft_divider</item>
    </style>

</resources>
