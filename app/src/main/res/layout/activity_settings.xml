<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="44dp"
        android:paddingBottom="28dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <View
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:layout_marginEnd="10dp"
                android:background="@color/rmsoft_accent" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_title"
                android:textColor="@color/rmsoft_text_primary"
                android:textSize="26sp"
                android:textStyle="bold"
                android:letterSpacing="0.02" />
        </LinearLayout>

        <!-- ── Network ─────────────────────────────────────────────────────── -->
        <TextView style="@style/Settings.SectionLabel" android:text="@string/settings_network" />

        <LinearLayout style="@style/Settings.Card">

            <LinearLayout
                android:id="@+id/wifiRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:paddingVertical="6dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_wifi"
                        android:textColor="@color/rmsoft_text_primary"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_wifi_subtitle"
                        android:textColor="@color/rmsoft_text_tertiary"
                        android:textSize="13sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textColor="@color/rmsoft_text_secondary"
                    android:textSize="24sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- ── Display ─────────────────────────────────────────────────────── -->
        <TextView style="@style/Settings.SectionLabel" android:text="@string/settings_display" />

        <LinearLayout style="@style/Settings.Card">

            <TextView style="@style/Settings.RowLabel" android:text="@string/settings_brightness" />

            <SeekBar
                android:id="@+id/brightnessSeek"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="255" />
        </LinearLayout>

        <!-- ── Sound ───────────────────────────────────────────────────────── -->
        <TextView style="@style/Settings.SectionLabel" android:text="@string/settings_sound" />

        <LinearLayout style="@style/Settings.Card">

            <TextView style="@style/Settings.RowLabel" android:text="@string/settings_media" />
            <SeekBar
                android:id="@+id/mediaSeek"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <TextView style="@style/Settings.RowLabel" android:text="@string/settings_ringtone" />
            <SeekBar
                android:id="@+id/ringSeek"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <TextView style="@style/Settings.RowLabel" android:text="@string/settings_call" />
            <SeekBar
                android:id="@+id/callSeek"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- ── Device info ─────────────────────────────────────────────────── -->
        <TextView style="@style/Settings.SectionLabel" android:text="@string/settings_device" />

        <LinearLayout style="@style/Settings.Card">

            <TextView style="@style/Settings.InfoLabel" android:text="@string/settings_device_name" />
            <TextView android:id="@+id/deviceName" style="@style/Settings.InfoValue" />

            <View style="@style/Settings.InfoDivider" />

            <TextView style="@style/Settings.InfoLabel" android:text="@string/settings_android_version" />
            <TextView android:id="@+id/androidVersion" style="@style/Settings.InfoValue" />

            <View style="@style/Settings.InfoDivider" />

            <TextView style="@style/Settings.InfoLabel" android:text="@string/settings_storage" />
            <TextView android:id="@+id/storageInfo" style="@style/Settings.InfoValue" />

            <View style="@style/Settings.InfoDivider" />

            <TextView style="@style/Settings.InfoLabel" android:text="@string/settings_battery" />
            <TextView android:id="@+id/batteryInfo" style="@style/Settings.InfoValue" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
