<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_home">

    <!-- Brand + clock -->
    <LinearLayout
        android:id="@+id/homeHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="52dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RMsoft OS"
            android:textColor="@color/rm_green_deep"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.02" />

        <TextClock
            android:id="@+id/homeClock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/rm_ink"
            android:textSize="52sp"
            android:format12Hour="hh:mm"
            android:format24Hour="HH:mm" />

        <TextClock
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/rm_slate"
            android:textSize="13sp"
            android:format12Hour="EEE, d MMM"
            android:format24Hour="EEE, d MMM" />
    </LinearLayout>

    <!-- Search pill -->
    <LinearLayout
        android:id="@+id/homeSearch"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="14dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="@drawable/bg_search_pill"
        app:layout_constraintTop_toBottomOf="@id/homeHeader"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_search"
            android:contentDescription="@null" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Search apps"
            android:textColor="@color/rm_slate"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- App grid -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/homeGrid"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="14dp"
        android:paddingHorizontal="14dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/homeSearch"
        app:layout_constraintBottom_toTopOf="@id/homeDock"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Dock -->
    <LinearLayout
        android:id="@+id/homeDock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="20dp"
        android:paddingVertical="8dp"
        android:paddingHorizontal="8dp"
        android:background="@drawable/bg_dock"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
