<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- Adjust system screen brightness from the custom Settings screen. -->
    <uses-permission android:name="android.permission.WRITE_SETTINGS"
        tools:ignore="ProtectedPermissions" />
    <!-- Required so the system can bind to our DeviceAdminReceiver as Device Owner. -->
    <uses-permission android:name="android.permission.BIND_DEVICE_ADMIN" />

    <!-- MDM device agent: network + foreground polling service. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <!-- The agent maintains a persistent MQTT link (dataSync) AND reports GPS (location) for Track. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Location reporting in telemetry (auto-granted by Device Owner). -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <!-- Network location: scan nearby WiFi + cell towers, sent to the server for Google Geolocation
         resolution so LOCATE works INDOORS (no GPS). -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- eSIM-only enforcement: read the SIM list, then disable physical SIMs. MODIFY_PHONE_STATE is
         a privileged/system permission — granted only when RMLauncher is baked into RMSoft OS as a
         privileged system app (allowlisted). SimPolicy no-ops safely without it. -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission
        android:name="android.permission.MODIFY_PHONE_STATE"
        tools:ignore="ProtectedPermissions" />
    <!-- Read the TRUE hardware serial (Build.getSerial → 3B240DLJH0013A) so a wiped + re-enrolled
         phone stays ONE record. signature|privileged — granted only to the baked privileged system
         app (allowlisted); a sideloaded /data build can't hold it and falls back to ANDROID_ID. -->
    <uses-permission
        android:name="android.permission.READ_PRIVILEGED_PHONE_STATE"
        tools:ignore="ProtectedPermissions" />

    <!-- "Vault": auto-provision Device Owner on every boot (incl. after a factory reset) so LOCK/WIPE
         survive a thief's reset. signature|privileged — granted only to the baked, allowlisted system
         app; a sideloaded build can't hold them (auto-provisioning no-ops there). -->
    <uses-permission android:name="android.permission.MANAGE_DEVICE_ADMINS"
        tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.MANAGE_PROFILE_AND_DEVICE_OWNERS"
        tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.WRITE_SECURE_SETTINGS"
        tools:ignore="ProtectedPermissions" />

    <!--
      Package visibility (Android 11+). We deliberately do NOT use QUERY_ALL_PACKAGES — Play Protect
      treats it (with device-admin + overlay) as a high-risk "device admin abuse" signal and blocks
      the app during QR provisioning. The Device Owner is already exempt from visibility filtering in
      production, so purge/inventory keep working; these <queries> entries keep the app picker and
      stock-app resolution working before Device Owner is active and in non-managed/debug builds.
    -->
    <queries>
        <!-- Every launchable app — app picker (AppInventory) + compass match (AppResolver). -->
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
        <!-- Stock-app role resolution (AppResolver): phone, messages, contacts, calculator, clock, camera. -->
        <intent>
            <action android:name="android.intent.action.DIAL" />
        </intent>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.APP_MESSAGING" />
        </intent>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.APP_CONTACTS" />
        </intent>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.APP_CALCULATOR" />
        </intent>
        <intent>
            <action android:name="android.intent.action.SHOW_ALARMS" />
        </intent>
        <intent>
            <action android:name="android.media.action.STILL_IMAGE_CAMERA" />
        </intent>
    </queries>

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/Theme.RMSOFTLauncher"
        tools:ignore="UnusedAttribute">

        <!-- Background-agent mode: RMSoft OS keeps its normal launcher; this app is an INVISIBLE
             MDM agent (no HOME role, no launcher icon). The old kiosk LauncherActivity is retained
             but not registered as a launcher/home — it's only used if kiosk mode is ever enabled. -->
        <activity
            android:name=".ui.LauncherActivity"
            android:exported="false"
            android:launchMode="singleTask"
            android:stateNotNeeded="true"
            android:resumeWhilePausing="true"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustPan" />

        <!-- Custom restricted Settings screen -->
        <activity
            android:name=".ui.SettingsActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.RMSOFTLauncher.Settings" />

        <!-- PIN-gated admin control panel (reached via long-press on the launcher brand title) -->
        <activity
            android:name=".ui.AdminActivity"
            android:exported="false"
            android:launchMode="singleTop"
            android:excludeFromRecents="true"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.RMSOFTLauncher.Settings" />

        <!-- Branded first-boot @rmsoft.rw enrollment gate (shown when unenrolled). -->

        <!-- Full-screen alert for admin-pushed messages (SHOW_MESSAGE command) -->
        <activity
            android:name=".ui.MessageActivity"
            android:exported="false"
            android:launchMode="singleTop"
            android:excludeFromRecents="true"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.RMSOFTLauncher.Settings" />

        <!-- First-run Welcome: branded splash + skippable RMSoft Mail suggestion. Shown once on
             first boot (BootReceiver), then never again. -->
        <activity
            android:name=".ui.WelcomeActivity"
            android:exported="false"
            android:launchMode="singleTask"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.RMSOFTLauncher.Welcome" />

        <!-- RMSoft Mail: WebView wrapper for mail.rmsoft.rw, shown as its own launchable app so the
             user gets a native-feeling mailbox (and can pick it as their mail app). -->
        <activity
            android:name=".ui.MailActivity"
            android:exported="true"
            android:label="RMSoft Mail"
            android:icon="@drawable/ic_mail_app"
            android:launchMode="singleTask"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.RMSOFTLauncher.Mail">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- NOTE: the branded home is now AOSP Launcher3 (full launcher: app drawer, drag-to-dock,
             widgets), branded via an OS overlay (RMSoft wallpaper + name) in the RMSoft OS build.
             RMLauncher is the invisible MDM agent + Welcome + RMSoft Mail — it is NOT the home.
             (HomeActivity.kt is kept but no longer registered as a HOME activity.) -->

        <!--
          Android 10+ managed-provisioning handshake. After QR / NFC / cloud enrollment downloads
          the APK, installs it, and grants Device Owner, the setup wizard hands off to these two
          intents. Without an activity to answer them, provisioning aborts with "Can't set up
          device" on Android 10+ (ADB `dpm set-device-owner` skips this handshake — why the lab
          path worked but QR didn't). GET_PROVISIONING_MODE declares a fully-managed device;
          ADMIN_POLICY_COMPLIANCE applies the kiosk policies and lets the wizard finish.
        -->
        <activity
            android:name=".ui.ProvisioningActivity"
            android:exported="true"
            android:theme="@style/Theme.RMSOFTLauncher.Settings">
            <intent-filter>
                <action android:name="android.app.action.GET_PROVISIONING_MODE" />
                <action android:name="android.app.action.ADMIN_POLICY_COMPLIANCE" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- Boot receiver: start the MDM agent on boot / after self-update -->
        <receiver
            android:name=".utils.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <!-- Fired to our own app right after it's updated — relaunch the kiosk immediately. -->
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <!--
          Install-session result receiver. When a dashboard INSTALL_APK finishes, this whitelists +
          unhides the new package and refreshes the home grid, so the app actually appears and isn't
          purged by the next policy sweep. The session targets this action on our own package, so the
          implicit-broadcast restriction doesn't apply.
        -->
        <receiver
            android:name=".remote.ApkInstallReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.rmsoft.launcher.APK_INSTALL_STATUS" />
            </intent-filter>
        </receiver>

        <!--
          Anti-theft SIM-swap watcher. On any SIM state change it re-checks the SIM against the
          enrollment baseline; a swap locks the phone + queues a server alert. SIM_STATE_CHANGED is a
          protected broadcast a privileged system app receives. Exported so the system can deliver it.
        -->
        <receiver
            android:name=".remote.SimChangeReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.SIM_STATE_CHANGED" />
            </intent-filter>
        </receiver>

        <!-- MDM device agent: foreground service that polls the server for commands + telemetry -->
        <service
            android:name=".remote.AgentService"
            android:exported="false"
            android:foregroundServiceType="dataSync|location" />

        <!--
          Device Owner admin receiver. Drives Lock Task (kiosk) Mode and all lockdown policies,
          and is the component targeted by Android Enterprise QR / EMM provisioning. The
          PROFILE_PROVISIONING_COMPLETE filter is what lets onProfileProvisioningComplete fire
          at the end of factory-reset → 6-tap → QR-scan provisioning.
        -->
        <receiver
            android:name=".utils.RMSOFTAdminReceiver"
            android:permission="android.permission.BIND_DEVICE_ADMIN"
            android:exported="true">
            <meta-data
                android:name="android.app.device_admin"
                android:resource="@xml/device_admin" />
            <intent-filter>
                <action android:name="android.app.action.DEVICE_ADMIN_ENABLED" />
                <action android:name="android.app.action.PROFILE_PROVISIONING_COMPLETE" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
